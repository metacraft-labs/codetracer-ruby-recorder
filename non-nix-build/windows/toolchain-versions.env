# Version pins for codetracer-ruby-recorder Windows dev environment.
# Tools: Rust (GNU target), Cap'n Proto (prebuilt), Nim, just, MSYS2 MinGW
# Ruby + gcc.
RUSTUP_VERSION=1.28.2
RUST_TOOLCHAIN_VERSION=1.92.0
CAPNP_VERSION=1.3.0
CAPNP_WIN_X64_SHA256=2c503361f8bf26fa9e7caccb6db04d6b271d5f0ad3da0616cf40e9a51335c89c
# Ruby is provided by the MSYS2 MinGW64 toolchain (see MSYS2_* below). The
# native extension links MinGW Ruby and builds for x86_64-pc-windows-gnu, so
# Ruby cannot come from RubyInstaller (that is MSVC ABI). 3.3+ is required;
# the pinned MSYS2 base ships Ruby 3.4.x.
RUBY_VERSION=3.4
# Nim is needed because the native extension depends on
# codetracer_trace_writer_nim, whose build script compiles a Nim static lib.
NIM_VERSION=2.2.8
# just runs the Justfile recipes (the documented dev interface).
JUST_VERSION=1.46.0
# --- MSYS2 (MinGW64 Ruby + gcc) ---
# env.ps1 extracts this dated msys2-base self-extracting archive, then runs
# `pacman -Syu` and installs the MinGW64 toolchain packages. The base archive
# date is the deterministic pin; pacman then resolves the current MinGW
# packages from the rolling repo (MSYS2 has no per-package version archive).
# A MinGW gcc is required because (a) the Rust x86_64-pc-windows-gnu target
# needs a MinGW linker and (b) codetracer_trace_writer_nim's build runs
# `nim --cc:gcc` for that target.
MSYS2_BASE_DATE=20260322
MSYS2_BASE_SHA256=6FE0CC8154132040E034FF4DAFACE2A4163A9D1F6EBAAA1133394BFF460BD5CF
# MinGW64 packages installed via pacman after the base is extracted.
# The clang package provides libclang.dll *and* clang's builtin resource
# headers (mm_malloc.h, the intrinsic headers, ...). rb-sys's bindgen build
# step needs both to generate the Ruby C API bindings: without the resource
# headers, parsing <malloc.h> fails on a missing mm_malloc.h.
MSYS2_MINGW_PACKAGES=mingw-w64-x86_64-gcc mingw-w64-x86_64-ruby mingw-w64-x86_64-make mingw-w64-x86_64-pkgconf mingw-w64-x86_64-clang
